# name: examples/sql/summary_counts.test
# description: table_diff_summary reports counts and percentages per diff_status
# group: [duck_diff]
#
# Use this shape when you want a tolerance threshold rather than exact equality
# (e.g. fail CI only when pct_different exceeds some budget).

require duck_diff


# === models ================================================================
#   1 identical, 1 different, 1 left_only, 1 right_only -> 4 keys total

statement ok
CREATE TABLE expected_users (
    id     INTEGER,
    name   VARCHAR,
    score  DOUBLE
);

statement ok
INSERT INTO expected_users VALUES
    (1, 'a', 10.0),
    (2, 'b', 20.0),
    (3, 'c', 30.0);

statement ok
CREATE TABLE actual_users (
    id     INTEGER,
    name   VARCHAR,
    score  DOUBLE
);

statement ok
INSERT INTO actual_users VALUES
    (1, 'a', 10.0),
    (2, 'B', 20.0),
    (4, 'd', 40.0);


# === assertion: counts =====================================================
# expected columns:  n_identical | n_different | n_left_only | n_right_only | n_total

query IIIII
SELECT n_identical, n_different, n_left_only, n_right_only, n_total
FROM table_diff_summary('FROM expected_users', 'FROM actual_users', pk := 'id');
----
1	1	1	1	4


# === assertion: percentages ================================================
# expected columns:  pct_identical | pct_different | pct_left_only | pct_right_only

query RRRR
SELECT pct_identical, pct_different, pct_left_only, pct_right_only
FROM table_diff_summary('FROM expected_users', 'FROM actual_users', pk := 'id');
----
25.0	25.0	25.0	25.0


# === assertion: threshold ("no more than 50% of keys may differ") ==========
# expected column:  boolean

query T
SELECT pct_different <= 50.0
FROM table_diff_summary('FROM expected_users', 'FROM actual_users', pk := 'id');
----
true
