# name: examples/sql/model_matches.test
# description: actual model produced by a transformation matches the expected (golden) model
# group: [duck_diff]
#
# Assertion idiom
# ---------------
# A model is correct iff table_diff_summary reports every key as identical:
#     n_different = n_left_only = n_right_only = 0   and   n_identical = n_total

require duck_diff


# === source model ==========================================================

statement ok
CREATE TABLE order_lines (
    order_id  INTEGER,
    customer  VARCHAR,
    amount    DECIMAL(10, 2)
);

statement ok
INSERT INTO order_lines VALUES
    (1, 'alice', 10.00),
    (1, 'alice',  5.00),
    (2, 'bob',   20.00),
    (3, 'carol',  7.50),
    (3, 'carol',  2.50);


# === expected (golden) model ===============================================

statement ok
CREATE TABLE expected_customer_revenue (
    customer  VARCHAR,
    revenue   DECIMAL(10, 2),
    n_orders  BIGINT
);

statement ok
INSERT INTO expected_customer_revenue VALUES
    ('alice', 15.00, 1),
    ('bob',   20.00, 1),
    ('carol', 10.00, 1);


# === transformation -> actual model ========================================

statement ok
CREATE TABLE actual_customer_revenue AS
SELECT
    customer,
    SUM(amount)::DECIMAL(10, 2)  AS revenue,    -- SUM widens to DECIMAL(38,2); cast back to match
    COUNT(DISTINCT order_id)     AS n_orders
FROM order_lines
GROUP BY customer;


# === assertion: every key identical ========================================
# expected columns:  n_identical | n_different | n_left_only | n_right_only | n_total

query IIIII
SELECT n_identical, n_different, n_left_only, n_right_only, n_total
FROM table_diff_summary(
    'FROM expected_customer_revenue',
    'FROM actual_customer_revenue',
    pk := 'customer'
);
----
3	0	0	0	3
