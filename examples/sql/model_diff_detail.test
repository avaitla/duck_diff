# name: examples/sql/model_diff_detail.test
# description: table_diff surfaces the exact per-key discrepancy when models drift
# group: [duck_diff]
#
# Exercises every diff_status value:
#     identical  | row present in both, all compared columns equal
#     different  | row present in both, at least one column differs
#     left_only  | key only in the expected model (a dropped row)
#     right_only | key only in the actual model   (an unexpected row)

require duck_diff


# === expected (golden) model ===============================================

statement ok
CREATE TABLE expected_users (
    id     INTEGER,
    name   VARCHAR,
    score  DOUBLE
);

statement ok
INSERT INTO expected_users VALUES
    (1, 'a', 10.0),
    (2, 'b', 20.0),
    (3, 'c', 30.0);


# === actual model (intentionally drifted) ==================================
#   id 1 -> unchanged        (identical)
#   id 2 -> name b becomes B (different)
#   id 3 -> missing          (left_only)
#   id 4 -> unexpected row   (right_only)

statement ok
CREATE TABLE actual_users (
    id     INTEGER,
    name   VARCHAR,
    score  DOUBLE
);

statement ok
INSERT INTO actual_users VALUES
    (1, 'a', 10.0),
    (2, 'B', 20.0),
    (4, 'd', 40.0);


# === assertion: per-key status =============================================
# expected columns:  id | diff_status

query IT
SELECT id, diff_status
FROM table_diff('FROM expected_users', 'FROM actual_users', pk := 'id')
ORDER BY id;
----
1	identical
2	different
3	left_only
4	right_only


# === assertion: diff_data names the changed column =========================
# expected column:  diff_data (JSON)

query T
SELECT diff_data
FROM table_diff('FROM expected_users', 'FROM actual_users', pk := 'id')
WHERE id = 2;
----
{"name":{"left":"b","right":"B"}}
