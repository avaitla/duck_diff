# A second example: grouped aggregates plus a `statement error` check.

statement ok
CREATE TABLE t (g VARCHAR, v INTEGER);

statement ok
INSERT INTO t VALUES ('a', 1), ('a', 2), ('b', 3);

# count and sum per group
query TII
SELECT g, COUNT(*), SUM(v) FROM t GROUP BY g ORDER BY g;
----
a	2	3
b	1	3

# `statement error` asserts the SQL is rejected — here, a primary-key clash.
statement ok
CREATE TABLE u (id INTEGER PRIMARY KEY);

statement ok
INSERT INTO u VALUES (1);

statement error
INSERT INTO u VALUES (1);
