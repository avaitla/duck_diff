# name: test/sql/table_diff_context.test
# description: context columns -- 'context' pulls extra (non-compared) columns into the <c>_left/<c>_right expansion
# group: [sql]

require table_diff

require json

statement ok
CREATE TABLE cxl (id INTEGER, amount INTEGER, name VARCHAR);

statement ok
CREATE TABLE cxr (id INTEGER, amount INTEGER, name VARCHAR);

statement ok
INSERT INTO cxl VALUES
    (1, 10, 'Acme'),   -- identical
    (3, 30, 'Gone'),   -- left_only
    (5, 50, 'Eve');    -- different (amount)

statement ok
INSERT INTO cxr VALUES
    (1, 10, 'Acme'),   -- identical
    (5, 99, 'Eva'),    -- different
    (7, 70, 'New');    -- right_only

# ----------------------------------------------------------------------------
# context := ['name'] expands 'name' into name_left / name_right. 'name' is
# excluded from comparison via ignore, so it has no name_diff_status and shows
# up only as context. The absent side of a one-sided row is NULL.
# ----------------------------------------------------------------------------
query ITT
SELECT id, name_left, name_right
FROM table_diff('FROM cxl', 'FROM cxr', pk := 'id', ignore := ['name'], context := ['name'])
ORDER BY id;
----
1	Acme	Acme
3	Gone	NULL
5	Eve	Eva
7	NULL	New

# a context column has no _diff_status (only compared columns do)
statement error
SELECT name_diff_status FROM table_diff('FROM cxl', 'FROM cxr', pk := 'id', ignore := ['name'], context := ['name']);
----
name_diff_status

# diff_data still reflects only the compared, differing columns (amount)
query T
SELECT json_keys(diff_data)
FROM table_diff('FROM cxl', 'FROM cxr', pk := 'id', ignore := ['name'], context := ['name'])
WHERE id = 5;
----
[amount]

# an ignored column not in context is not produced at all
statement error
SELECT name_left FROM table_diff('FROM cxl', 'FROM cxr', pk := 'id', ignore := ['name']);
----
name_left

# ----------------------------------------------------------------------------
# context := ['*'] with columns present on only one side: each non-key column is
# expanded, NULL on the side it is absent from (require_matching_columns := false
# so the differing column sets don't error)
# ----------------------------------------------------------------------------
statement ok
CREATE TABLE osl (id INTEGER, a INTEGER, only_l VARCHAR);

statement ok
CREATE TABLE osr (id INTEGER, a INTEGER, only_r VARCHAR);

statement ok
INSERT INTO osl VALUES (1, 10, 'L1'), (2, 20, 'L2');

statement ok
INSERT INTO osr VALUES (1, 10, 'R1'), (2, 99, 'R2');

# compared 'a' expands to a_left/a_right/a_diff_status; the one-sided
# 'only_l'/'only_r' expand to _left/_right, NULL on the side they lack.
query ITIITTT
SELECT id, diff_status, a_left, a_right, a_diff_status, only_l_left, only_r_right
FROM table_diff('FROM osl', 'FROM osr', pk := 'id', require_matching_columns := false, context := ['*'])
ORDER BY id;
----
1	identical	10	10	identical	L1	R1
2	different	20	99	different	L2	R2

# ----------------------------------------------------------------------------
# context := ['*'] surfaces the full row for left_only / right_only rows (an
# orphan row has no diff_data, so the expanded columns are where its values show)
# ----------------------------------------------------------------------------
statement ok
CREATE TABLE orl (id INTEGER, amt INTEGER, note VARCHAR);

statement ok
CREATE TABLE orr (id INTEGER, amt INTEGER, note VARCHAR);

statement ok
INSERT INTO orl VALUES (1, 10, 'a');

statement ok
INSERT INTO orr VALUES (1, 10, 'a'), (2, 99, 'orphan');

# id 2 is right_only: left values NULL, right values carry the whole row
query TTTT
SELECT diff_status, amt_left, amt_right, note_right
FROM table_diff('FROM orl', 'FROM orr', pk := 'id', context := ['*'])
WHERE id = 2;
----
right_only	NULL	99	orphan
