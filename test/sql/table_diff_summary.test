# name: test/sql/table_diff_summary.test
# description: table_diff_summary counts and equality check
# group: [sql]

require duck_diff

require json

statement ok
CREATE TABLE l (id INTEGER, v INTEGER);

statement ok
CREATE TABLE r (id INTEGER, v INTEGER);

statement ok
INSERT INTO l VALUES (1, 1), (2, 2), (3, 3), (5, 5);

statement ok
INSERT INTO r VALUES (1, 1), (2, 99), (4, 4), (5, 5);

# ----------------------------------------------------------------------------
# table_diff_summary: one row of counts per status
#   identical: keys 1,5   -> 2
#   different: key 2      -> 1
#   left_only: key 3    -> 1
#   right_only: key 4   -> 1
# ----------------------------------------------------------------------------
query IIII
SELECT n_identical, n_different, n_left_only, n_right_only
FROM table_diff_summary('FROM l', 'FROM r', pk := 'id');
----
2	1	1	1

# total and percentages (of 5 total rows)
query IRRRR
SELECT n_total, pct_identical, pct_different, pct_left_only, pct_right_only
FROM table_diff_summary('FROM l', 'FROM r', pk := 'id');
----
5	40.0	20.0	20.0	20.0

# ----------------------------------------------------------------------------
# equality check (simulated from the summary): false when anything
# different/added/removed
# ----------------------------------------------------------------------------
query T
SELECT n_different + n_left_only + n_right_only = 0
FROM table_diff_summary('FROM l', 'FROM r', pk := 'id');
----
false

# true when every key matches
statement ok
CREATE TABLE r2 (id INTEGER, v INTEGER);

statement ok
INSERT INTO r2 VALUES (1, 1), (2, 2), (3, 3), (5, 5);

query T
SELECT n_different + n_left_only + n_right_only = 0
FROM table_diff_summary('FROM l', 'FROM r2', pk := 'id');
----
true
