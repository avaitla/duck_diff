# name: test/sql/table_diff_summary.test
# description: table_diff_summary counts and tables_equal
# group: [duck_diff]

require duck_diff

require json

statement ok
CREATE TABLE l (id INTEGER, v INTEGER);

statement ok
CREATE TABLE r (id INTEGER, v INTEGER);

statement ok
INSERT INTO l VALUES (1, 1), (2, 2), (3, 3), (5, 5);

statement ok
INSERT INTO r VALUES (1, 1), (2, 99), (4, 4), (5, 5);

# ----------------------------------------------------------------------------
# table_diff_summary: one row of counts per status
#   matched: keys 1,5   -> 2
#   differs: key 2      -> 1
#   left_only: key 3    -> 1
#   right_only: key 4   -> 1
# ----------------------------------------------------------------------------
query IIII
SELECT n_matched, n_differs, n_left_only, n_right_only
FROM table_diff_summary(TABLE l, TABLE r, key := 'id');
----
2	1	1	1

statement ok
DROP TABLE r;

statement ok
CREATE TABLE r (id INTEGER, v INTEGER);

statement ok
INSERT INTO r VALUES (1, 1), (2, 2), (3, 3), (5, 5);

# ----------------------------------------------------------------------------
# tables_equal: true when every key is matched, false otherwise
# ----------------------------------------------------------------------------
query I
SELECT tables_equal(TABLE l, TABLE r, key := 'id');
----
true

statement ok
UPDATE r SET v = 0 WHERE id = 2;

query I
SELECT tables_equal(TABLE l, TABLE r, key := 'id');
----
false

# missing key also breaks equality
statement ok
DELETE FROM r WHERE id = 3;

query I
SELECT tables_equal(TABLE l, TABLE r, key := 'id');
----
false
