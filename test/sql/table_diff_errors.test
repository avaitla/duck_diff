# name: test/sql/table_diff_errors.test
# description: v1 error cases (required pk, missing key, duplicate keys)
# group: [sql]

require duck_diff

require json

statement ok
CREATE TABLE a (id INTEGER, x INTEGER);

statement ok
CREATE TABLE b (id INTEGER, x INTEGER);

statement ok
INSERT INTO a VALUES (1, 10);

statement ok
INSERT INTO b VALUES (1, 10);

# ----------------------------------------------------------------------------
# pk is required
# ----------------------------------------------------------------------------
statement error
SELECT * FROM table_diff('FROM a', 'FROM b');
----
pk

# pk column must exist in both relations
statement error
SELECT * FROM table_diff('FROM a', 'FROM b', pk := 'nope');
----
nope

# ----------------------------------------------------------------------------
# Duplicate primary keys -> error (key must be unique on both sides)
# ----------------------------------------------------------------------------
statement ok
CREATE TABLE dl (id INTEGER, v INTEGER);

statement ok
CREATE TABLE dr (id INTEGER, v INTEGER);

statement ok
INSERT INTO dl VALUES (1, 1), (1, 2);

statement ok
INSERT INTO dr VALUES (1, 1);

statement error
SELECT * FROM table_diff('FROM dl', 'FROM dr', pk := 'id');
----
duplicate

# duplicate on the right side is also an error
statement ok
DELETE FROM dl WHERE v = 2;

statement ok
INSERT INTO dr VALUES (1, 9);

statement error
SELECT * FROM table_diff('FROM dl', 'FROM dr', pk := 'id');
----
duplicate

# ----------------------------------------------------------------------------
# Relation arguments are queries: a bare relation name is rejected, the explicit
# 'FROM tbl' / 'SELECT * FROM tbl' forms are accepted.
# ----------------------------------------------------------------------------
statement ok
CREATE TABLE qa (id INTEGER, v INTEGER);

statement ok
INSERT INTO qa VALUES (1, 10);

# bare name on the left -> parse error, message nudges toward FROM
statement error
SELECT * FROM table_diff('qa', 'FROM qa', pk := 'id');
----
SELECT * FROM tbl

# both explicit forms work and agree (table matches itself)
query IT
SELECT id, diff_status FROM table_diff('FROM qa', 'SELECT * FROM qa', pk := 'id');
----
1	identical

# a projecting SELECT is a valid relation argument
query IT
SELECT id, diff_status FROM table_diff('SELECT id, v FROM qa', 'FROM qa', pk := 'id');
----
1	identical
