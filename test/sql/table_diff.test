# name: test/sql/table_diff.test
# description: table_diff core behavior
# group: [duck_diff]

# Before the extension is loaded, the function does not exist.
statement error
SELECT * FROM table_diff(TABLE l, TABLE r, key := 'id');
----
Catalog Error

require duck_diff

require json

# ----------------------------------------------------------------------------
# Fixtures
# ----------------------------------------------------------------------------
# Three value columns of different types so we exercise type preservation in
# the JSON diff (number=INTEGER, email=VARCHAR, score=DOUBLE).

statement ok
CREATE TABLE l (id INTEGER, number INTEGER, email VARCHAR, score DOUBLE);

statement ok
CREATE TABLE r (id INTEGER, number INTEGER, email VARCHAR, score DOUBLE);

statement ok
INSERT INTO l VALUES
    (1, 10, 'a@x', 1.5),   -- matched
    (3, 30, 'c@x', 3.5),   -- left_only
    (5, 50, 'e@x', 5.5),   -- differs (number + email)
    (8, 80, NULL,  8.5),   -- matched (NULL email both sides)
    (9, 90, 'i@x', 9.5);   -- differs (email NULL on right only)

statement ok
INSERT INTO r VALUES
    (1, 10, 'a@x', 1.5),   -- matched
    (5, 99, 'E@x', 5.5),   -- differs (number + email)
    (7, 70, 'g@x', 7.5),   -- right_only
    (8, 80, NULL,  8.5),   -- matched (NULL email both sides)
    (9, 90, NULL,  9.5);   -- differs (email NULL on right)

# ----------------------------------------------------------------------------
# Status column: every key gets exactly one row with the right status
# ----------------------------------------------------------------------------
query IT
SELECT pk_id, status FROM table_diff(TABLE l, TABLE r, key := 'id') ORDER BY pk_id;
----
1	matched
3	left_only
5	differs
7	right_only
8	matched
9	differs

# Row count == number of distinct keys across both sides
query I
SELECT count(*) FROM table_diff(TABLE l, TABLE r, key := 'id');
----
6

# ----------------------------------------------------------------------------
# diff column is NULL for everything except 'differs'
# ----------------------------------------------------------------------------
query IT
SELECT pk_id, diff FROM table_diff(TABLE l, TABLE r, key := 'id')
WHERE status <> 'differs' ORDER BY pk_id;
----
1	NULL
3	NULL
7	NULL
8	NULL

# ----------------------------------------------------------------------------
# diff content: only differing columns appear
# ----------------------------------------------------------------------------
# key 5 differs on number and email but NOT score -> score absent
query I
SELECT json_keys(diff) FROM table_diff(TABLE l, TABLE r, key := 'id') WHERE pk_id = 5;
----
[number, email]

# left/right values for key 5
query TT
SELECT diff->'number'->>'left', diff->'number'->>'right'
FROM table_diff(TABLE l, TABLE r, key := 'id') WHERE pk_id = 5;
----
10	99

query TT
SELECT diff->'email'->>'left', diff->'email'->>'right'
FROM table_diff(TABLE l, TABLE r, key := 'id') WHERE pk_id = 5;
----
e@x	E@x

# ----------------------------------------------------------------------------
# NULL semantics: NULL IS NOT DISTINCT FROM NULL -> matched (key 8)
# ----------------------------------------------------------------------------
query T
SELECT status FROM table_diff(TABLE l, TABLE r, key := 'id') WHERE pk_id = 8;
----
matched

# value vs NULL -> differs, and NULL is represented as JSON null (key 9, email)
query T
SELECT json_keys(diff) FROM table_diff(TABLE l, TABLE r, key := 'id') WHERE pk_id = 9;
----
[email]

query TT
SELECT diff->'email'->>'left', json_type(diff->'email'->'right')
FROM table_diff(TABLE l, TABLE r, key := 'id') WHERE pk_id = 9;
----
i@x	NULL

# ----------------------------------------------------------------------------
# Type preservation in JSON: int stays a number, string stays a string
# ----------------------------------------------------------------------------
query TT
SELECT json_type(diff->'number'->'left'), json_type(diff->'email'->'left')
FROM table_diff(TABLE l, TABLE r, key := 'id') WHERE pk_id = 5;
----
UBIGINT	VARCHAR

# ----------------------------------------------------------------------------
# Relation input: subqueries / read-like sources, not just named tables
# ----------------------------------------------------------------------------
query IT
SELECT pk_id, status FROM table_diff(
    (SELECT * FROM l WHERE id <= 3),
    (SELECT * FROM r WHERE id <= 3),
    key := 'id'
) ORDER BY pk_id;
----
1	matched
3	left_only

# ----------------------------------------------------------------------------
# Identical relations -> all matched, no diffs
# ----------------------------------------------------------------------------
query I
SELECT count(*) FROM table_diff(TABLE l, TABLE l, key := 'id') WHERE status <> 'matched';
----
0
